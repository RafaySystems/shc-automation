# Copy this to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Controller SSH overrides (optional — can use dev.yaml instead)
# CONTROLLER_IP=129.146.108.42
# CONTROLLER_SSH_KEY=/path/to/key.pem
# CONTROLLER_USER=ubuntu

# Controller profile overrides
# CONTROLLER_SIZE=S
# CONTROLLER_HA=false
# CONTROLLER_OS_TYPE=ubuntu24

# OCI overrides
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxx
# OCI_SUBNET_ID=ocid1.subnet.oc1..xxx
# OCI_VCN_ID=ocid1.vcn.oc1..xxx
# OCI_IMAGE_ID=ocid1.image.oc1..xxx
# OCI_SHAPE=VM.Standard.E4.Flex
# OCI_OCPUS=16
# OCI_MEMORY_GB=64
# OCI_CONFIG_FILE=~/.oci/config
# OCI_PROFILE=DEFAULT
# OCI_SSH_PUBLIC_KEY=/path/to/key.pub
# OCI_DISPLAY_NAME=shc-{build_no}

# Skip OCI VM creation (use existing IP)
# SKIP_OCI_CREATE=1

# Jenkins build number (used in display_name)
# BUILD_NUMBER=42
